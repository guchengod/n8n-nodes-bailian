{
	"name": "n8n-nodes-bailian",
	"version": "0.17.0",
	"description": "阿里云DashScope API集成的n8n节点",
	"license": "MIT",
	"homepage": "https://help.aliyun.com/document_detail/2400305.html",
	"keywords": [
		"n8n-community-node-package",
		"n8n",
		"aliyun",
		"bailian",
		"dashscope"
	],
	"author": {
		"name": "guchengod",
		"email": "guchengod@gmail.com"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/guchengod/n8n-nodes-bailian.git"
	},
	"scripts": {
		"build": "n8n-node build",
		"build:watch": "tsc --watch",
		"dev": "n8n-node dev",
		"lint": "n8n-node lint",
		"lint:fix": "n8n-node lint --fix",
		"release": "n8n-node release",
		"prepublishOnly": "n8n-node prerelease"
	},
	"files": [
		"dist"
	],
	"n8n": {
		"n8nNodesApiVersion": 1,
		"strict": false,
		"credentials": [
			"dist/credentials/DashScopeApi.credentials.js"
		],
		"nodes": [
			"dist/nodes/DashScope/DashScope.node.js"
		]
	},
	"devDependencies": {
		"@n8n/node-cli": "*",
		"@types/node": "^25.3.3",
		"eslint": "^9.39.3",
		"n8n-workflow": "^1.120.9",
		"prettier": "3.5.3",
		"release-it": "^18.1.2",
		"typescript": "5.8.2"
	},
	"peerDependencies": {
		"n8n-workflow": "*"
	},
	"dependencies": {
		"axios": "^1.13.6"
	}
}
